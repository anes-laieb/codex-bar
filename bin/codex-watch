#!/usr/bin/env python3
"""codex-watch — infer Codex activity from rollout logs and drive the menu-bar
state file + native notifications.

Codex has no statusline API and (on the sandboxed Desktop build) may not run
third-party `notify` hooks, but it writes a JSONL "rollout" log per session
under $CODEX_HOME/sessions/YYYY/MM/DD/rollout-*.jsonl. This watcher tails the
most-recently-active rollout, maps events to a state, writes one word to
$CODEX_HOME/state (idle | working | needs-approval), and fires a notification
when a turn completes (or when an approval is requested, on versions that log
one).

Robustness: a line that doesn't parse is skipped and the last state is held;
the watcher never crashes on malformed/rotated logs. Event/field names are read
from the log as-is, and unknown events are ignored, so it degrades gracefully
across Codex versions.

Modes:
  codex-watch                 Run the watcher loop (default; used by LaunchAgent).
  codex-watch --print-state   Print the current inferred state and exit.
  codex-watch --replay FILE   Replay a rollout file through the engine, printing
                              the state transitions and notifications it WOULD
                              fire (no real notifications). For testing.

Config via environment:
  CODEX_HOME               default ~/.codex
  CODEX_STATUS_POLL        poll seconds (default 0.5)
  CODEX_STATUS_HEARTBEAT   rewrite state file at least this often (default 10)
  CODEX_STATUS_SOUND_DONE  sound for turn-complete (default "Glass"; "" silent)
  CODEX_STATUS_SOUND_APPR  sound for approval (default "Funk"; "" silent)
  CODEX_STATUS_ACTIVATE    bundle id to focus on click (default: auto-detect
                           /Applications/ChatGPT.app, else unset)
  CODEX_STATUS_NOTIFY      "1" (default) to send notifications, "0" to disable
  CODEX_STATUS_NOTIFIER    path to the notifier program (default: the bundled
                           codex-notifier next to this script)
"""
import argparse
import json
import os
import plistlib
import subprocess
import sys
import time

IDLE = "idle"
WORKING = "working"
APPROVAL = "needs-approval"

# Terminal state-changing event payload types (event_msg.payload.type).
_START = {"task_started"}
_DONE = {"task_complete"}
_ABORT = {"turn_aborted"}
# Approval detection is best-effort: not observed on every version, so we match
# on substrings and treat request-like events as "needs approval". Endings that
# indicate a *resolution* rather than a request are excluded.
_APPROVAL_HINT = ("approval", "elicit")
_RESOLVED_SUFFIX = ("end", "output", "complete", "completed", "decision",
                    "response", "resolved", "denied", "approved")


def codex_home():
    return os.environ.get("CODEX_HOME") or os.path.join(os.path.expanduser("~"), ".codex")


def sessions_dir(home):
    return os.path.join(home, "sessions")


def sound_enabled(home):
    """Whether the completion sound is on (toggled via codex-status-sound)."""
    try:
        with open(os.path.join(home, "codex-macos-status", "sound"), "r", encoding="utf-8") as f:
            return f.read().strip() != "off"
    except OSError:
        return True  # default on


class Engine:
    """Pure state machine over rollout events. No I/O — unit-testable.

    feed(obj) returns a dict:
      {"state": <new state or None>, "notify": (title, body, kind) or None}
    'state' is set only when the state actually changes. 'notify' is advisory;
    the driver decides whether to actually send it (suppressed while catching up
    on pre-existing history).
    """

    def __init__(self, state=IDLE):
        self.state = state
        self.last_message = None
        self.started_at = None   # epoch of the in-progress turn (task_started)
        self.duration_ms = None  # duration of the last completed turn

    def _set(self, new):
        if new != self.state:
            self.state = new
            return new
        return None

    @staticmethod
    def _looks_like_approval_request(key):
        if not any(h in key for h in _APPROVAL_HINT):
            return False
        return not any(key.endswith(s) for s in _RESOLVED_SUFFIX)

    @staticmethod
    def _extract_command(p):
        for k in ("command", "cmd", "call", "input", "action"):
            v = p.get(k)
            if isinstance(v, str) and v.strip():
                return v.strip()
            if isinstance(v, list) and v:
                try:
                    return " ".join(str(x) for x in v)
                except Exception:
                    pass
        return None

    def feed(self, obj):
        out = {"state": None, "notify": None}
        if not isinstance(obj, dict):
            return out
        t = obj.get("type")
        p = obj.get("payload")
        if not isinstance(p, dict):
            return out
        pt = p.get("type") or ""
        key = (str(t) + "/" + str(pt)).lower()

        # Approval request (best-effort; may never occur on this version).
        if self._looks_like_approval_request(key):
            out["state"] = self._set(APPROVAL)
            cmd = self._extract_command(p)
            out["notify"] = ("Codex needs approval", cmd or pt, "approval")
            return out

        if t == "event_msg":
            if pt in _START:
                self.started_at = p.get("started_at")
                out["state"] = self._set(WORKING)
            elif pt in _DONE:
                self.last_message = p.get("last_agent_message") or p.get("last-assistant-message")
                self.duration_ms = p.get("duration_ms")
                out["state"] = self._set(IDLE)
                out["notify"] = ("Codex — ready for you", (self.last_message or "").strip(), "complete")
            elif pt in _ABORT:
                self.duration_ms = p.get("duration_ms")
                out["state"] = self._set(IDLE)
        return out


# ---------- I/O helpers ----------

def newest_rollout(home):
    """Path of the most-recently-modified rollout file, or None."""
    root = sessions_dir(home)
    newest, newest_m = None, -1.0
    for dirpath, _dirs, files in os.walk(root):
        for name in files:
            if name.startswith("rollout-") and name.endswith(".jsonl"):
                fp = os.path.join(dirpath, name)
                try:
                    m = os.path.getmtime(fp)
                except OSError:
                    continue
                if m > newest_m:
                    newest, newest_m = fp, m
    return newest


def scan_boundary(path):
    """Scan a rollout for its latest task boundary, seeding state + turn info."""
    info = {"state": IDLE, "started_at": None, "duration_ms": None, "last_message": None}
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    o = json.loads(line)
                except Exception:
                    continue
                if o.get("type") != "event_msg":
                    continue
                p = o.get("payload") or {}
                pt = p.get("type")
                if pt in _START:
                    info["state"] = WORKING
                    info["started_at"] = p.get("started_at")
                elif pt in _DONE:
                    info["state"] = IDLE
                    info["duration_ms"] = p.get("duration_ms")
                    info["last_message"] = p.get("last_agent_message") or p.get("last-assistant-message")
                elif pt in _ABORT:
                    info["state"] = IDLE
                    info["duration_ms"] = p.get("duration_ms")
    except OSError:
        pass
    return info


def seed_engine(path):
    """Build an Engine pre-loaded from a rollout's latest boundary."""
    b = scan_boundary(path)
    e = Engine(state=b["state"])
    e.started_at = b["started_at"]
    e.duration_ms = b["duration_ms"]
    e.last_message = b["last_message"]
    return e


def write_state(home, state):
    path = os.path.join(home, "state")
    tmp = path + ".tmp"
    try:
        with open(tmp, "w", encoding="utf-8") as f:
            f.write(state + "\n")
        os.replace(tmp, path)
    except OSError:
        pass


# Fields the menu-bar plugin reads. session_meta carries cwd/originator/version;
# turn_context carries model/effort/approval_policy.
_META_KEYS = ("cwd", "originator", "cli_version", "model", "effort", "approval_policy")


def _blank_meta():
    return {k: "" for k in _META_KEYS}


def update_meta(meta, obj):
    """Absorb model/project/etc. from a session_meta or turn_context event."""
    if not isinstance(obj, dict):
        return
    t = obj.get("type")
    p = obj.get("payload")
    if not isinstance(p, dict):
        return
    if t == "session_meta":
        for k in ("cwd", "originator", "cli_version"):
            if p.get(k):
                meta[k] = p[k]
    elif t == "turn_context":
        for k in ("cwd", "model", "effort", "approval_policy"):
            if p.get(k):
                meta[k] = p[k]


def scan_meta(path):
    """Read a whole rollout for the freshest session_meta + turn_context fields."""
    meta = _blank_meta()
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    update_meta(meta, json.loads(line))
                except Exception:
                    continue
    except OSError:
        pass
    return meta


def config_model(home):
    """Fallback model name from config.toml (root `model = "..."`)."""
    try:
        with open(os.path.join(home, "config.toml"), "r", encoding="utf-8") as f:
            for raw in f:
                s = raw.strip()
                if s.startswith("[") :
                    break
                if s.startswith("model") and "=" in s:
                    return s.split("=", 1)[1].strip().strip('"').strip("'")
    except OSError:
        pass
    return ""


def write_status(home, eng, meta):
    """Write a TAB-separated status file for the menu-bar plugin (atomic)."""
    model = meta.get("model") or config_model(home)
    msg = (eng.last_message or "").replace("\n", " ").replace("\t", " ").strip()
    fields = [
        ("state", eng.state),
        ("model", model),
        ("effort", meta.get("effort", "")),
        ("approval_policy", meta.get("approval_policy", "")),
        ("cwd", meta.get("cwd", "")),
        ("originator", meta.get("originator", "")),
        ("cli_version", meta.get("cli_version", "")),
        ("started_at", str(eng.started_at or "")),
        ("duration_ms", str(eng.duration_ms or "")),
        ("last_message", msg[:500]),
        ("updated_at", str(int(time.time()))),
    ]
    path = os.path.join(home, "status")
    tmp = path + ".tmp"
    try:
        with open(tmp, "w", encoding="utf-8") as f:
            for k, v in fields:
                f.write("%s\t%s\n" % (k, v))
        os.replace(tmp, path)
    except OSError:
        pass


def detect_activate():
    env = os.environ.get("CODEX_STATUS_ACTIVATE")
    if env is not None:
        return env or None
    plist = "/Applications/ChatGPT.app/Contents/Info.plist"
    try:
        with open(plist, "rb") as f:
            data = plistlib.load(f)
        return data.get("CFBundleIdentifier") or None
    except Exception:
        return None


def dispatch_notify(notifier, title, body, kind, activate):
    if os.environ.get("CODEX_STATUS_NOTIFY", "1") != "1":
        return
    body = body or ("Turn complete" if kind == "complete" else "")
    if len(body) > 200:
        body = body[:197] + "..."
    if kind == "approval":
        sound = os.environ.get("CODEX_STATUS_SOUND_APPR", "Funk")
    else:
        sound = os.environ.get("CODEX_STATUS_SOUND_DONE", "Glass")
    if not sound_enabled(codex_home()):
        sound = ""
    args = [notifier, title, body, "", sound, "codex-status", activate or ""]
    try:
        subprocess.run(args, timeout=10, check=False,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass


def notifier_path():
    # Explicit override wins (used for testing and custom notifiers).
    env = os.environ.get("CODEX_STATUS_NOTIFIER")
    if env:
        return os.path.abspath(os.path.expanduser(env))
    # The notifier ships alongside this script in the repo (../bin) or next to it
    # once installed. Try same-dir first, then a couple of known layouts.
    here = os.path.dirname(os.path.abspath(__file__))
    for cand in (os.path.join(here, "codex-notifier"),
                 os.path.join(here, "..", "bin", "codex-notifier")):
        if os.path.isfile(cand) and os.access(cand, os.X_OK):
            return os.path.abspath(cand)
    return os.path.join(here, "codex-notifier")


# ---------- run modes ----------

def run_replay(path):
    eng = Engine()
    print(f"# replay {path}\n# initial state: {eng.state}")
    n_lines = n_events = 0
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            n_lines += 1
            line = line.strip()
            if not line:
                continue
            try:
                o = json.loads(line)
            except Exception:
                continue
            res = eng.feed(o)
            if res["state"] or res["notify"]:
                n_events += 1
                bits = []
                if res["state"]:
                    bits.append(f"STATE -> {res['state']}")
                if res["notify"]:
                    tt, bb, kk = res["notify"]
                    bb = (bb[:80] + "…") if len(bb) > 80 else bb
                    bits.append(f"NOTIFY[{kk}] {tt!r}: {bb!r}")
                print("  " + " | ".join(bits))
    print(f"# {n_lines} lines, {n_events} state/notify actions, final state: {eng.state}")
    return 0


def run_print_state(home):
    f = newest_rollout(home)
    print(scan_boundary(f)["state"] if f else IDLE)
    return 0


def run_loop(home):
    poll = float(os.environ.get("CODEX_STATUS_POLL", "0.5"))
    heartbeat = float(os.environ.get("CODEX_STATUS_HEARTBEAT", "10"))
    activate = detect_activate()
    notifier = notifier_path()

    cur_path = newest_rollout(home)
    eng = seed_engine(cur_path) if cur_path else Engine()
    meta = scan_meta(cur_path) if cur_path else _blank_meta()
    offset = 0
    if cur_path:
        try:
            offset = os.path.getsize(cur_path)  # skip history on the first file
        except OSError:
            offset = 0
    buf = ""
    write_state(home, eng.state)
    write_status(home, eng, meta)
    last_written = eng.state
    last_beat = _mono()

    while True:
        try:
            newest = newest_rollout(home)
            if newest and newest != cur_path:
                # A newer session appeared; process it from the beginning so we
                # catch its completion, but seed state + meta from the file.
                cur_path = newest
                eng = seed_engine(cur_path)
                meta = scan_meta(cur_path)
                offset = 0
                buf = ""

            if cur_path:
                size = os.path.getsize(cur_path)
                if size < offset:      # file truncated/rotated
                    offset = 0
                    buf = ""
                if size > offset:
                    with open(cur_path, "r", encoding="utf-8", errors="replace") as f:
                        f.seek(offset)
                        chunk = f.read()
                        offset = f.tell()
                    buf += chunk
                    lines = buf.split("\n")
                    buf = lines.pop()        # keep trailing partial line
                    for line in lines:
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            o = json.loads(line)
                        except Exception:
                            continue        # hold last state on parse error
                        update_meta(meta, o)   # keep model/project/etc. current
                        res = eng.feed(o)
                        if res["state"] and res["state"] != last_written:
                            write_state(home, res["state"])
                            write_status(home, eng, meta)
                            last_written = res["state"]
                        if res["notify"]:
                            tt, bb, kk = res["notify"]
                            dispatch_notify(notifier, tt, bb, kk, activate)

            now = _mono()
            if now - last_beat >= heartbeat:
                write_state(home, eng.state)   # liveness heartbeat
                write_status(home, eng, meta)
                last_written = eng.state
                last_beat = now
        except Exception:
            # Never let the loop die; hold last state and keep polling.
            pass
        time.sleep(poll)


def _mono():
    # time.monotonic is available on 3.9; kept in a helper to centralise clock use.
    return time.monotonic()


def main(argv):
    ap = argparse.ArgumentParser(prog="codex-watch")
    g = ap.add_mutually_exclusive_group()
    g.add_argument("--print-state", action="store_true")
    g.add_argument("--replay", metavar="FILE")
    ns = ap.parse_args(argv)
    home = codex_home()
    if ns.replay:
        return run_replay(ns.replay)
    if ns.print_state:
        return run_print_state(home)
    return run_loop(home)


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except KeyboardInterrupt:
        sys.exit(0)

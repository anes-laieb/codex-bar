#!/usr/bin/env python3
"""codex-notify-hook — OPTIONAL, event-driven Codex `notify` hook handler.

The primary notification + state path in codex-macos-status is codex-watch,
which reads rollout logs and needs no config change. This handler is for users
whose Codex build actually runs third-party `notify` hooks (the sandboxed
Desktop build may not) and who want an extra, edge-triggered notification.

Codex passes a single JSON string as the LAST argv argument. That JSON's schema
varies by Codex version and was NOT observed on the Desktop build here, so this
parses DEFENSIVELY across likely key names and never crashes on bad input.

Usage (config.toml):
  notify = ["/abs/codex-notify-hook"]                    # notify only
  notify = ["/abs/codex-notify-hook", "PREV", "ARG"]     # also forward to PREV

Env: CODEX_STATUS_NOTIFIER, CODEX_STATUS_SOUND_DONE, CODEX_STATUS_SOUND_APPR,
     CODEX_STATUS_NOTIFY (set "0" to disable).
"""
import json
import os
import subprocess
import sys


def notifier():
    env = os.environ.get("CODEX_STATUS_NOTIFIER")
    if env:
        return os.path.abspath(os.path.expanduser(env))
    here = os.path.dirname(os.path.abspath(__file__))
    return os.path.join(here, "codex-notifier")


def send(title, body, sound):
    if os.environ.get("CODEX_STATUS_NOTIFY", "1") != "1":
        return
    body = (body or "").strip()
    if len(body) > 200:
        body = body[:197] + "..."
    try:
        subprocess.run([notifier(), title, body, "", sound, "codex-status", ""],
                       timeout=10, check=False,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass


def main(argv):
    # Forward to a previously-configured hook if leading args are present.
    # argv == [PREV, PREV_ARGS..., JSON]; re-running argv preserves it.
    if len(argv) >= 2:
        try:
            subprocess.run(list(argv), timeout=15, check=False,
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception:
            pass

    raw = argv[-1] if argv else ""
    try:
        obj = json.loads(raw)
    except Exception:
        return 0
    if not isinstance(obj, dict):
        return 0

    t = str(obj.get("type", "")).lower()
    if "approval" in t or "elicit" in t:
        cmd = obj.get("command") or obj.get("cmd") or ""
        if isinstance(cmd, list):
            cmd = " ".join(str(x) for x in cmd)
        send("Codex needs approval", cmd or t,
             os.environ.get("CODEX_STATUS_SOUND_APPR", "Funk"))
    elif ("turn" in t and "complete" in t) or "agent-turn" in t or t in ("agent-turn-complete",):
        msg = (obj.get("last-assistant-message") or obj.get("last_agent_message")
               or obj.get("message") or obj.get("assistant-message") or "")
        send("Codex — ready for you", msg,
             os.environ.get("CODEX_STATUS_SOUND_DONE", "Glass"))
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except Exception:
        sys.exit(0)
